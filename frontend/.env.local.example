# Firebase (Auth) - 从 Firebase Console → Project settings → General → Your apps → Web app 复制
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=ledgerlens-484819.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=ledgerlens-484819
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=ledgerlens-484819.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=891554344619
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Backend API：本机用 localhost 即可。若从手机或本机 IP（如 192.168.x.x:3000）访问前端，
# 须改为后端真实地址，例如 ngrok 的 https://xxx.ngrok.io 或 http://本机IP:8000（后端需监听 0.0.0.0）
NEXT_PUBLIC_API_URL=http://localhost:8000

# 可选：Supabase 仅用于数据库时保留（登录已迁到 Firebase）
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
