# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# 手机/局域网测试时：设为当前访问的 base URL（如 http://10.0.0.51:3000），
# 登录邮件里的链接才会跳回该地址。同时需在 Supabase → Authentication → URL Configuration → Redirect URLs 里添加该 callback，如 http://10.0.0.51:3000/auth/callback
# NEXT_PUBLIC_APP_URL=http://10.0.0.51:3000
